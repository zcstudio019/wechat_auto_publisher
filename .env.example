# Application environment
APP_ENV=development

# Web admin panel
WEB_HOST=127.0.0.1
WEB_PORT=5000
WEB_AUTO_RELOAD=true
WEB_USERNAME=admin
WEB_PASSWORD=admin123
EDITOR_USERNAME=editor
EDITOR_PASSWORD=editor123
OPERATOR_USERNAME=operator
OPERATOR_PASSWORD=operator123

# Database settings
DB_BACKEND=sqlite
DB_PATH=data/articles.db
DB_HOST=your-rds.mysql.rds.aliyuncs.com
DB_PORT=3306
DB_NAME=wechat_auto_publisher
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_CHARSET=utf8mb4

# WeChat public account settings
WECHAT_APP_ID=your_appid_here
WECHAT_APP_SECRET=your_appsecret_here
WECHAT_LEAD_FORM_URL=https://your-domain.com/lead-form

# AI settings
OPENAI_API_KEY=your_text_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_IMAGE_API_KEY=your_image_openai_api_key_here
OPENAI_IMAGE_BASE_URL=https://your-image-provider.com/v1
OPENAI_IMAGE_MODEL=gpt-image-2

# Publish and scheduler settings
DAILY_ARTICLE_COUNT=3
PUBLISH_HOUR=9
PUBLISH_MINUTE=0
PUBLISH_HOUR_MORNING=8
PUBLISH_HOUR_EVENING=20
REVIEW_APPROVE_EXECUTE_IMMEDIATELY=true
SYSTEM_EVENTS_MAX_KEEP=20
