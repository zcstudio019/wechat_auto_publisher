# ====================
# 应用环境
# ====================
# development: 本地开发；production: ECS 生产部署
APP_ENV=development

# ====================
# Web 管理后台
# ====================
WEB_HOST=127.0.0.1
WEB_PORT=5000
WEB_AUTO_RELOAD=true
WEB_USERNAME=admin
WEB_PASSWORD=admin123

# 可选：多角色账号
EDITOR_USERNAME=editor
EDITOR_PASSWORD=editor123
OPERATOR_USERNAME=operator
OPERATOR_PASSWORD=operator123

# ====================
# 数据库配置
# ====================
# 本地开发默认使用 SQLite；生产部署改为 mysql。
DB_BACKEND=sqlite
DB_PATH=data/articles.db

# 阿里云 RDS MySQL 生产配置；DB_BACKEND=mysql 时必填。
DB_HOST=your-rds.mysql.rds.aliyuncs.com
DB_PORT=3306
DB_NAME=wechat_auto_publisher
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_CHARSET=utf8mb4

# ====================
# 微信公众号配置
# ====================
WECHAT_APP_ID=your_appid_here
WECHAT_APP_SECRET=your_appsecret_here

# 公众号正文里的留资入口必须是公网 HTTPS 地址。
# 本地开发可留空，系统会使用 /lead-form 预览；生产建议填写完整域名。
WECHAT_LEAD_FORM_URL=https://your-domain.com/lead-form

# ====================
# AI 内容生成配置
# ====================
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1

# ====================
# 发布与调度配置
# ====================
DAILY_ARTICLE_COUNT=3
PUBLISH_HOUR=9
PUBLISH_MINUTE=0
PUBLISH_HOUR_MORNING=8
PUBLISH_HOUR_EVENING=20

# 审核通过后是否立即同步执行发布任务。
# 生产异步化后可考虑设为 false，由独立 Scheduler 消费 queued 任务。
REVIEW_APPROVE_EXECUTE_IMMEDIATELY=true

# 系统事件时间线最多保留条数
SYSTEM_EVENTS_MAX_KEEP=20
